rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Returns true if the requester is a signed-in Firebase Auth user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the requester has the admin Custom Claim set.
    // Set this claim via Admin SDK: auth.setCustomUserClaims(uid, { admin: true })
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Returns true if the requesting user owns the document
    // (their Auth UID matches the document's stored uid field).
    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // ── Members collection ─────────────────────────────────────────────────────
    // Document ID == Firebase Auth UID.
    match /Members/{uid} {
      // A member can only read their own profile; admins can read all.
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);

      // Only admins can list/query the full collection (e.g., for the leaderboard backend).
      // Members access their own doc via the direct path above.
      allow list: if isAdmin();

      // Members can create their own document on registration (uid must match).
      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.role == "member"; // Cannot self-assign admin

      // Members can update their own profile; admins can update any.
      allow update: if isAdmin() || (isOwner() && request.auth.uid == uid);

      // Only admins can delete member documents.
      allow delete: if isAdmin();
    }

    // ── Vouchers collection ───────────────────────────────────────────────────
    match /vouchers/{voucherId} {
      // Members can read only their own vouchers; admins can read all.
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);

      // Only Cloud Functions (admin SDK, bypasses rules) create/update vouchers.
      allow write: if isAdmin();
    }

    // ── VoucherGroup collection (campaigns) ───────────────────────────────────
    match /voucherGroup/{groupId} {
      // All authenticated users can read active campaigns.
      allow read: if isAuthenticated();

      // Only admins can create or modify campaigns.
      allow write: if isAdmin();
    }

    // ── CompetitionRecords collection ─────────────────────────────────────────
    match /competitionRecords/{monthId} {
      // All authenticated users can read leaderboard data.
      allow read: if isAuthenticated();

      // Only Cloud Functions write competition records.
      allow write: if isAdmin();
    }

    // ── Feedbacks collection ──────────────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      // Members can create feedback and read their own; admins can read all.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.memberId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Products collection (public catalog) ──────────────────────────────────
    match /products/{productId} {
      allow read: if true; // Public — no auth required to browse the menu
      allow write: if isAdmin();
    }

    match /products_test/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
